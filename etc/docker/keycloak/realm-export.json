{
  "realm": "ecommerce",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "roles": {
    "realm": [
      { "name": "ORDER_READ", "description": "Allows reading orders" },
      { "name": "ORDER_WRITE", "description": "Allows placing orders" }
    ]
  },
  "clients": [
    {
      "clientId": "ecommerce-app",
      "name": "E-commerce showcase client",
      "enabled": true,
      "publicClient": true,
      "protocol": "openid-connect",
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": [ "*" ]
    }
  ],
  "users": [
    {
      "username": "order-admin",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        { "type": "password", "value": "password", "temporary": false }
      ],
      "realmRoles": [ "ORDER_READ", "ORDER_WRITE" ]
    },
    {
      "username": "order-viewer",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        { "type": "password", "value": "password", "temporary": false }
      ],
      "realmRoles": [ "ORDER_READ" ]
    }
  ]
}
